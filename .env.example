# ===========================================
# MediaEditor Platform - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# STRIPE CONFIGURATION (Subscription)
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for plans (legacy - kept for backward compat)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_ONETIME=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# AI tier subscription prices
STRIPE_PRICE_AI_LITE_MONTHLY=price_...    # 480 JPY/month
STRIPE_PRICE_AI_LITE_YEARLY=price_...     # 3,980 JPY/year
STRIPE_PRICE_AI_PRO_MONTHLY=price_...     # 980 JPY/month
STRIPE_PRICE_AI_PRO_YEARLY=price_...      # 7,980 JPY/year

# AI credit pack prices (one-time)
STRIPE_PRICE_PACK_S=price_...             # 1,980 JPY / 200 credits
STRIPE_PRICE_PACK_M=price_...             # 4,980 JPY / 600 credits
STRIPE_PRICE_PACK_L=price_...             # 9,800 JPY / 1,500 credits
STRIPE_PRICE_LIFETIME=price_...           # 14,800 JPY / unlimited

# ===========================================
# FEATURE FLAGS
# ===========================================

# Set to 'true' to enable AI features and pricing page
NEXT_PUBLIC_AI_ENABLED=false

# ===========================================
# AI API KEYS (for AI features)
# ===========================================
# These are optional - AI features will be disabled without them

# Remove.bg API for background removal
REMOVEBG_API_KEY=

# Replicate API for AI upscaling
REPLICATE_API_TOKEN=

# OpenAI API for AI features
OPENAI_API_KEY=

# fal.ai (hub for video/image models - Seedance, Kling, Veo, FLUX, etc.)
FAL_KEY=

# Stability AI (Inpaint, Erase)
STABILITY_API_KEY=

# Gemini (Nano Banana image gen + free assistant)
GOOGLE_GENERATIVE_AI_API_KEY=

# xAI Grok (Aurora image, Imagine video, 4.1 chat)
XAI_API_KEY=

# Deep-Image.ai (Outpainting)
DEEP_IMAGE_API_KEY=

# ===========================================
# CONTACT FORM EMAIL DELIVERY
# ===========================================

# Resend API key for contact auto-send
RESEND_API_KEY=

# Optional sender address shown in received contact emails
# Default: onboarding@resend.dev
CONTACT_FROM_EMAIL=

# ===========================================
# GENERAL CONFIGURATION
# ===========================================

# Application URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# ===========================================
# SECURITY SETTINGS
# ===========================================

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX_REQUESTS=100

# Maximum file size in bytes (2GB = 2147483648)
MAX_FILE_SIZE=2147483648

# ===========================================
# ANALYTICS (Optional)
# ===========================================

# Google Analytics
NEXT_PUBLIC_GA_TRACKING_ID=

# Sentry for error tracking
SENTRY_DSN=
